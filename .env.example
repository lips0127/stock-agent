# ═══════════════════════════════════════
# A股股息监测系统 — 环境变量配置模板
# ═══════════════════════════════════════

# ── Python 后端 ──
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=false

# ── JWT（⚠️ 生产环境必须更改！） ──
JWT_SECRET=change-me-in-production-256bit
JWT_EXPIRATION_HOURS=2

# ── 调度器 ──
SCHEDULER_HOUR=15
SCHEDULER_MINUTE=30
SCAN_MAX_WORKERS=20

# ── 缓存 ──
CACHE_DIR=./data
CACHE_EXPIRE_HOURS=6

# ── CORS ──
CORS_ORIGINS=*

# ── 日志 ──
LOG_LEVEL=INFO

# ── Gunicorn ──
GUNICORN_WORKERS=2

# ── 默认管理员 ──
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Nginx ──
NGINX_PORT=80
